# https://www.youtube.com/watch?v=u2Juz5sQyYQ
# https://www.youtube.com/watch?v=3tK8-5MdWGU
# lspci (nix run nixpkgs#pciutils)
# https://github.com/torvalds/linux/blob/master/kernel/configs/tiny.config

CONFIG_EXPERT=y
CONFIG_PRINTK=y

CONFIG_KERNEL_ZSTD=y
CONFIG_CC_OPTIMIZE_FOR_SIZE=y

CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y

CONFIG_BLK_DEV_INITRD=y

CONFIG_BINFMT_SCRIPT=y
CONFIG_BINFMT_ELF=y

CONFIG_PCI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_VIRTIO_MENU=y
CONFIG_VIRTIO_PCI=y

CONFIG_NET=y
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y
CONFIG_VIRTIO_NET=y

CONFIG_INET=y
CONFIG_UNIX=y
CONFIG_PACKET=y

CONFIG_BLOCK=y
CONFIG_BLK_DEV=y
CONFIG_VIRTIO_BLK=y

# TODO: support nvme, very expensive machine use nvme
# CONFIG_BLK_DEV_NVME

CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_SCSI_LOWLEVEL=y
CONFIG_SCSI_VIRTIO=y

CONFIG_ATA=y
CONFIG_SATA_AHCI=y

CONFIG_ISO9660_FS=y

CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y

CONFIG_EFI=y
CONFIG_ACPI=y

# tty0
CONFIG_TTY=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

CONFIG_DRM=y
# virtio-gpu-pci
CONFIG_DRM_VIRTIO_GPU=y
CONFIG_DRM_VIRTIO_GPU_KMS=y
# bridge drm to fb console
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_FRAMEBUFFER_CONSOLE=y


# virtio keyboard (-device virtio-keyboard-pci)
CONFIG_VIRTIO_INPUT=y

# usb keyboard (XHCI USB 3.0)
CONFIG_USB_SUPPORT=y
CONFIG_USB=y
CONFIG_USB_PCI=y
CONFIG_USB_XHCI_HCD=y

CONFIG_HID_SUPPORT=y
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_USB_HID=y
