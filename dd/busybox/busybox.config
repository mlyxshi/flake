CONFIG_BUSYBOX=y
CONFIG_FEATURE_INSTALLER=y

# Custom
CONFIG_CLOUD_INIT_NETWORKCFG=y

# Sh
CONFIG_ASH=y
CONFIG_ASH_OPTIMIZE_FOR_SIZE=y
CONFIG_ASH_ECHO=y
CONFIG_ASH_TEST=y

# Utils
CONFIG_LS=y
CONFIG_POWEROFF=y
CONFIG_REBOOT=y
CONFIG_MKDIR=y
CONFIG_LN=y
CONFIG_MOUNT=y
CONFIG_DMESG=y
CONFIG_PS=y
CONFIG_TOP=y
CONFIG_CAT=y
CONFIG_FREE=y
CONFIG_FINDFS=y
CONFIG_FEATURE_VOLUMEID_ISO9660=y
CONFIG_FEATURE_VOLUMEID_EXT=y
CONFIG_FEATURE_VOLUMEID_FAT=y


# IP
CONFIG_IP=y
CONFIG_FEATURE_IP_ADDRESS=y
CONFIG_FEATURE_IP_LINK=y
CONFIG_FEATURE_IP_ROUTE=y

# Net
CONFIG_UDHCPC=y
CONFIG_WGET=y
CONFIG_FEATURE_WGET_HTTPS=y
CONFIG_NC=y
CONFIG_NC_SERVER=y
CONFIG_NC_EXTRA=y