CONFIG_REGULATOR=n
CONFIG_HWMON=n
CONFIG_WATCHDOG=n
CONFIG_MD=n
CONFIG_SPI=n
CONFIG_NEW_LEDS=n
CONFIG_CHROME_PLATFORMS=n
