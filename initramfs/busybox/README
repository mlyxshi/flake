Minimal BusyBox-based initrd for experimentation and learning.
For daily use, prefer a systemd-based initrd.




aka pkgsMusl
pkgsMuslDynamic = import <nixpkgs> {
  localSystem = {
    config = "aarch64-unknown-linux-musl";
  };
};

aka pkgsStatic
pkgsMuslStatic = import <nixpkgs> {
  localSystem = {
    config = "aarch64-unknown-linux-gnu";
  };
  crossSystem = {
    config = "aarch64-unknown-linux-musl";
    isStatic = true;
  };
};


wget https://github.com/mlyxshi/flake/releases/download/$(uname -m)/busybox-kernel
cat > /boot/grub/custom.cfg <<EOF
menuentry "KernelBusyBox" --id KernelBusyBox {
  insmod ext2
  search -f /etc/hostname --set root
  linux /root/busybox-kernel
}
set default="KernelBusyBox"
EOF
reboot

wget -qO- https://dd.mlyxshi.com/custom_os.img | dd of=/dev/sda
wget -qO- https://dd.mlyxshi.com/arm-init-grow.raw | dd of=/dev/sda
wget -qO- https://dd.mlyxshi.com/bios-init.raw | dd of=/dev/vda



wget https://github.com/mlyxshi/flake/releases/download/$(uname -m)/busybox-kernel
wget https://github.com/mlyxshi/flake/releases/download/$(uname -m)/kexec
chmod +x kexec
./kexec --load ./busybox-kernel
systemctl kexec -i



virtio_pci

virtio_net
af_packet

virtio_blk # -device virtio-blk-pci (/dev/vdX)

virtio_scsi # Virtio SCSI controller  # -device virtio-scsi-pci  
sd_mod # SCSI DISK driver (/dev/sdX) # -device scsi-hd
sr_mod # SCSI CD-ROM driver (/dev/srX) # cloud-init cidata disk

ahci # SATA controllers
isofs # mount /dev/sr1 /cloud-init

